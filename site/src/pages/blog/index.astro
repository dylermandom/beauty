---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title="Blog" description="Dicas de beleza, autoestima e cuidados do Thaise Beauty Studio.">
  <section class="secao">
    <div class="container">
      <p class="rotulo reveal">Blog</p>
      <h1 class="reveal">Dicas e novidades</h1>

      {
        posts.length > 0 ? (
          <div class="grid-posts">
            {posts.map((post, i) => (
              <a
                href={`/blog/${post.id}`}
                class="cartao post-card tilt reveal"
                style={`--atraso: ${i * 0.08}s`}
              >
                <h3>{post.data.title}</h3>
                <p>{post.data.excerpt}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="lead reveal">Primeiros posts chegando em breve, princess.</p>
        )
      }
    </div>
  </section>
</Base>

<style>
  .lead {
    font-size: 1.2rem;
  }

  .grid-posts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .post-card {
    display: block;
    padding: 1.75rem;
    text-decoration: none;
    color: var(--cor-texto);
  }

  .post-card h3 {
    margin-bottom: 0.5rem;
  }

  .post-card p {
    margin: 0;
    opacity: 0.85;
  }
</style>
